JARVIS_BACKEND_HOST=127.0.0.1
JARVIS_BACKEND_PORT=18000
VITE_JARVIS_API_BASE=http://127.0.0.1:18000

# Assistant identity
JARVIS_ASSISTANT_NAME=Джарвис
JARVIS_ASSISTANT_DISPLAY_NAME=JARVIS
JARVIS_ADDRESS_STYLE=сэр
JARVIS_WAKE_WORDS=джарвис,чарли,jarvis

# AI routing
JARVIS_AI_PRIMARY=groq
JARVIS_AI_FALLBACK=openrouter
JARVIS_AI_ALLOW_LOCAL_FALLBACK=true

# Groq
JARVIS_GROQ_API_KEY=
GROQ_API_KEY=
JARVIS_GROQ_MODEL=llama-3.1-8b-instant
JARVIS_GROQ_TIMEOUT_SECONDS=12
JARVIS_GROQ_MAX_TOKENS=180
JARVIS_GROQ_TEMPERATURE=0.4

# OpenRouter
JARVIS_OPENROUTER_API_KEY=
JARVIS_OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_MAX_TOKENS=180
OPENROUTER_TEMPERATURE=0.4
OPENROUTER_CONNECT_TIMEOUT=10
OPENROUTER_READ_TIMEOUT=20
OPENROUTER_TOTAL_TIMEOUT=30
OPENROUTER_MAX_RETRIES=1

# TTS routing
JARVIS_TTS_PRIMARY=fish_audio
TTS_PRIMARY=fish_audio
JARVIS_TTS_REQUIRE_FISH_AUDIO=true
TTS_REQUIRE_FISH_AUDIO=true
JARVIS_TTS_FALLBACK_ENABLED=false
TTS_FALLBACK_ENABLED=false
TTS_TIMEOUT_SECONDS=25

# Fish Audio voice profiles
JARVIS_FISH_AUDIO_API_KEY=
JARVIS_FISH_AUDIO_VOICE_ID=
JARVIS_FISH_AUDIO_VOICE_ID_2=
JARVIS_FISH_AUDIO_VOICE_ID_3=
JARVIS_VOICE_PROFILE_ID=jarvis_main
JARVIS_VOICE_TONE=calm

# Local voice provider registry
JARVIS_VOICE_PROVIDER=fish_audio
JARVIS_LOCAL_TTS_PROVIDER=piper
JARVIS_PIPER_ENABLED=false
JARVIS_PIPER_MODEL_PATH=models/piper/ru_RU.onnx
JARVIS_PIPER_CONFIG_PATH=models/piper/ru_RU.onnx.json
JARVIS_PIPER_EXE_PATH=
JARVIS_PIPER_SPEAKER_ID=
JARVIS_XTTS_ENABLED=false
JARVIS_XTTS_API_URL=http://127.0.0.1:8020
JARVIS_XTTS_MODEL_PATH=models/xtts
JARVIS_GPT_SOVITS_ENABLED=false
JARVIS_GPT_SOVITS_API_URL=http://127.0.0.1:9880
JARVIS_GPT_SOVITS_REFER_WAV=
JARVIS_GPT_SOVITS_PROMPT_TEXT=
JARVIS_GPT_SOVITS_PROMPT_LANG=ru
JARVIS_GPT_SOVITS_TEXT_LANG=ru
JARVIS_RVC_ENABLED=false
JARVIS_RVC_API_URL=http://127.0.0.1:7897

# Listener
JARVIS_LISTENER_ENABLED=true
JARVIS_LISTENER_AUTOSTART=true
JARVIS_LISTENER_DEVICE_ID=default
JARVIS_VOICE_WAKE_ENABLED=true
JARVIS_COMMAND_RECORD_SECONDS=6
JARVIS_COOLDOWN_MS=2500
JARVIS_IGNORE_SELF_AUDIO=true
JARVIS_CLAP_THRESHOLD=0.25
JARVIS_MIN_RMS_THRESHOLD=0.003
JARVIS_MAX_TRIGGERS_PER_MINUTE=6

# STT
JARVIS_STT_PROVIDER=vosk
JARVIS_VOSK_MODEL_PATH=models/vosk-model-small-ru-0.22
