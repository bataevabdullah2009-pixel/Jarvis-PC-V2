# Auto detect text files and perform LF normalization
* text=auto

/.gitattributes text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
.env.example text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
